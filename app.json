{
  "name": "TOOSII-XD ULTRA",
  "description": "A powerful WhatsApp bot with 947+ commands — AI, Games, Group Management, Media Tools, Anti-ViewOnce, Auto-reactions & more. Built with Baileys & Node.js.",
  "image": "https://i.ibb.co/Y4JyPsnk/Screenshot-2026-04-14-175511.png",
  "logo": "https://i.ibb.co/4g7rWmss/Chat-GPT-Image-Jan-28-2026-10-30-54-AM.png",
  "repository": "https://github.com/TOOSII102/toosii-xd-ultra",
  "keywords": [
    "whatsapp",
    "bot",
    "nodejs",
    "baileys",
    "multi-device"
  ],
  "env": {
    "SESSION_ID": {
      "description": "Your session ID — get it FREE at: https://toosiitechdevelopertools.zone.id/session",
      "value": "",
      "required": true
    },
    "OWNER_NUMBER": {
      "description": "Your WhatsApp number with country code, no + (e.g. 254712345678)",
      "value": "",
      "required": true
    },
    "PREFIX": {
      "description": "Bot command prefix (default: comma)",
      "value": ",",
      "required": false
    },
    "BOT_NAME": {
      "description": "Name of your bot",
      "value": "TOOSII-XD ULTRA",
      "required": false
    },
    "OWNER_NAME": {
      "description": "Your name shown in menus",
      "value": "",
      "required": false
    },
    "MODE": {
      "description": "public = everyone can use | private = owner only",
      "value": "public",
      "required": false
    },
    "TIME_ZONE": {
      "description": "Timezone for time commands (e.g. Africa/Nairobi)",
      "value": "Africa/Nairobi",
      "required": false
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}